# Environment variables — NEVER commit this file to version control
# Copy to .env and fill in real values

PORT=8080
LOG_FORMAT=text

# Hevy
HEVY_WEBHOOK_SECRET=your_hevy_shared_secret_here

# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string

# Turso (Phase 2)
TURSO_DB_URL=wss://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_jwt_here

# Google AI Studio (Phase 3)
GEMINI_API_KEY=your_gemini_key_here
